# .streamlit/secrets.toml
# Bu dosya ASLA GitHub'a yüklenmez! .gitignore'a ekleyin.
# Streamlit Cloud'da Settings > Secrets bölümüne yapıştırın.

# Supabase (opsiyonel - ücretsiz tier, 50K MAU)
# https://supabase.com adresinden ücretsiz proje açın
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-key-here"

